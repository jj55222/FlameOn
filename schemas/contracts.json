{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FlameOn Cross-Pipeline Data Contracts",
  "description": "Defines the exact JSON shape for every pipeline handoff. Each pipeline MUST validate its output against these before writing.",

  "definitions": {

    "case_packet": {
      "description": "Pipeline 2 canonical output. This is the downstream-ready packet emitted after identity locking, outcome resolution, artifact claims, and verified artifact URL resolution.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "input",
        "case_identity",
        "sources",
        "artifact_claims",
        "verified_artifacts",
        "scores",
        "verdict",
        "next_actions",
        "risk_flags"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable internal identifier for this case packet."
        },
        "input": {
          "type": "object",
          "additionalProperties": true,
          "required": ["mode"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "manual_defendant_jurisdiction",
                "wapo_uof_row",
                "muckrock_request",
                "courtlistener_docket",
                "youtube",
                "news_article",
                "agency_ois_page",
                "unknown"
              ]
            },
            "raw": {
              "type": "object",
              "additionalProperties": true
            },
            "missing_fields": {
              "type": "array",
              "items": { "type": "string" }
            },
            "candidate_queries": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "case_identity": {
          "$ref": "#/definitions/case_packet_identity"
        },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/definitions/case_packet_source" }
        },
        "artifact_claims": {
          "type": "array",
          "items": { "$ref": "#/definitions/case_packet_artifact_claim" },
          "description": "Claims found in source text. A claim is not a verified artifact URL."
        },
        "verified_artifacts": {
          "type": "array",
          "items": { "$ref": "#/definitions/case_packet_verified_artifact" },
          "description": "Concrete public URLs/files/embeds that have been deterministically associated with the case."
        },
        "scores": {
          "$ref": "#/definitions/case_packet_scores"
        },
        "verdict": {
          "type": "string",
          "enum": ["PRODUCE", "HOLD", "SKIP"]
        },
        "next_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risk_flags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "case_packet_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defendant_names",
        "victim_names",
        "agency",
        "jurisdiction",
        "incident_date",
        "case_numbers",
        "charges",
        "outcome_status",
        "identity_confidence",
        "identity_anchors"
      ],
      "properties": {
        "defendant_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "victim_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "agency": {
          "type": ["string", "null"]
        },
        "jurisdiction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["city", "county", "state"],
          "properties": {
            "city": { "type": ["string", "null"] },
            "county": { "type": ["string", "null"] },
            "state": { "type": ["string", "null"] }
          }
        },
        "incident_date": {
          "type": ["string", "null"],
          "description": "Known incident date if available. Prefer ISO-8601 strings when normalized."
        },
        "case_numbers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "charges": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outcome_status": {
          "type": "string",
          "enum": ["unknown", "charged", "convicted", "sentenced", "closed", "dismissed", "acquitted"]
        },
        "identity_confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "identity_anchors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "case_packet_source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["url", "title", "source_type", "source_authority"],
      "properties": {
        "url": { "type": "string" },
        "title": { "type": "string" },
        "snippet": { "type": "string" },
        "source_type": {
          "type": "string",
          "enum": ["web", "news", "official", "court", "foia", "video", "document", "api", "unknown"]
        },
        "source_authority": {
          "type": "string",
          "enum": ["official", "court", "foia", "news", "third_party", "unknown"]
        },
        "matched_case_fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "case_packet_artifact_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "claim_label", "claim_source_url", "claim_text", "confidence"],
      "properties": {
        "artifact_type": {
          "type": "string",
          "enum": ["bodycam", "interrogation", "court_video", "docket_docs", "dispatch_911", "dash_cam", "other"]
        },
        "claim_label": {
          "type": "string",
          "enum": ["artifact_released", "artifact_requested", "artifact_withheld", "artifact_mentioned_only", "no_artifact"]
        },
        "claim_source_url": {
          "type": "string",
          "description": "The source that made the claim. This is not necessarily the artifact URL."
        },
        "claim_text": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },

    "case_packet_verified_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "artifact_url", "source_authority", "downloadable", "matched_case_fields", "confidence"],
      "properties": {
        "artifact_type": {
          "type": "string",
          "enum": ["bodycam", "interrogation", "court_video", "docket_docs", "dispatch_911", "dash_cam", "other"]
        },
        "artifact_url": {
          "type": "string",
          "description": "The public URL/file/embed for the actual artifact."
        },
        "claim_source_url": {
          "type": "string",
          "description": "Optional source URL that first claimed this artifact existed."
        },
        "source_authority": {
          "type": "string",
          "enum": ["official", "court", "foia", "news", "third_party", "unknown"]
        },
        "downloadable": {
          "type": "boolean"
        },
        "matched_case_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },

    "case_packet_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity_score", "outcome_score", "artifact_score", "actionability_score"],
      "properties": {
        "identity_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "outcome_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "artifact_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "actionability_score": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },

    "case_packet_legacy_evaluate_shape": {
      "description": "Compatibility shape for the immutable legacy evaluate.py scorer.",
      "type": "object",
      "additionalProperties": true,
      "required": ["evidence_found", "sources_found", "confidence"],
      "properties": {
        "evidence_found": {
          "type": "object",
          "required": ["bodycam", "interrogation", "court_video", "docket_docs", "dispatch_911"],
          "properties": {
            "bodycam": { "type": "boolean" },
            "interrogation": { "type": "boolean" },
            "court_video": { "type": "boolean" },
            "docket_docs": { "type": "boolean" },
            "dispatch_911": { "type": "boolean" }
          }
        },
        "sources_found": {
          "type": "array",
          "items": { "type": "object" }
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    },

    "p2_to_p3_case": {
      "description": "Pipeline 2 (Discovery) → Pipeline 3 (Audio). One per case.",
      "type": "object",
      "required": ["case_id", "defendant", "jurisdiction", "sources", "research_score", "confidence_tier"],
      "properties": {
        "case_id": {
          "type": "string",
          "description": "Unique case identifier, format: lastname_jurisdiction_YYYY (e.g., smith_harris_county_tx_2023)"
        },
        "defendant": {
          "type": "string",
          "description": "Full defendant name as discovered"
        },
        "jurisdiction": {
          "type": "string",
          "description": "Jurisdiction string (county + state minimum)"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "evidence_type", "format"],
            "properties": {
              "url": {
                "type": "string",
                "format": "uri",
                "description": "Direct downloadable URL where possible"
              },
              "evidence_type": {
                "type": "string",
                "enum": ["bodycam", "interrogation", "court_video", "911_audio", "dash_cam", "news_report", "court_docket", "foia_document", "other"],
                "description": "What kind of evidence this source contains"
              },
              "format": {
                "type": "string",
                "enum": ["video", "audio", "document", "webpage"],
                "description": "Media format for Pipeline 3 routing"
              },
              "source_domain": {
                "type": "string",
                "description": "Domain the URL comes from (e.g., muckrock.com, youtube.com)"
              },
              "requires_download": {
                "type": "boolean",
                "description": "True if yt-dlp or similar tool needed vs. direct HTTP download"
              },
              "notes": {
                "type": "string",
                "description": "Any context about the source (e.g., 'partial footage, starts mid-encounter')"
              }
            }
          },
          "description": "All discovered source URLs, typed by evidence category"
        },
        "research_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Composite score from evaluate.py"
        },
        "confidence_tier": {
          "type": "string",
          "enum": ["ENOUGH", "BORDERLINE", "INSUFFICIENT"],
          "description": "Agent's confidence assessment"
        },
        "charges": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known charges if discovered"
        },
        "incident_date": {
          "type": "string",
          "description": "Approximate incident date if known (YYYY-MM-DD or YYYY-MM or YYYY)"
        },
        "summary": {
          "type": "string",
          "description": "One-paragraph case summary from research"
        }
      }
    },

    "p3_to_p4_transcript": {
      "description": "Pipeline 3 (Audio) → Pipeline 4 (Scoring). One per processed audio file.",
      "type": "object",
      "required": ["case_id", "source_evidence_type", "transcript", "original_duration_sec", "processed_duration_sec"],
      "properties": {
        "case_id": {
          "type": "string",
          "description": "Must match case_id from P2 output"
        },
        "source_evidence_type": {
          "type": "string",
          "enum": ["bodycam", "interrogation", "court_video", "911_audio", "dash_cam", "news_report", "other"],
          "description": "Which evidence type this transcript came from"
        },
        "source_url": {
          "type": "string",
          "description": "Original source URL from P2"
        },
        "transcript": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["start_sec", "end_sec", "text"],
            "properties": {
              "start_sec": {
                "type": "number",
                "description": "Start time in ORIGINAL video/audio (not trimmed)"
              },
              "end_sec": {
                "type": "number",
                "description": "End time in ORIGINAL video/audio (not trimmed)"
              },
              "text": {
                "type": "string"
              },
              "speaker": {
                "type": "string",
                "description": "Speaker label from diarization (SPEAKER_00, SPEAKER_01, etc.)"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Whisper word-level confidence if available"
              }
            }
          }
        },
        "silence_map": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["original_start_sec", "original_end_sec", "duration_sec"],
            "properties": {
              "original_start_sec": { "type": "number" },
              "original_end_sec": { "type": "number" },
              "duration_sec": { "type": "number" }
            }
          },
          "description": "Silence segments that were trimmed, in original timestamps"
        },
        "original_duration_sec": {
          "type": "number",
          "description": "Total duration of original audio before processing"
        },
        "processed_duration_sec": {
          "type": "number",
          "description": "Duration after silence trimming"
        },
        "speaker_count": {
          "type": "integer",
          "description": "Number of distinct speakers identified by diarization"
        },
        "processing_metadata": {
          "type": "object",
          "properties": {
            "whisper_model": { "type": "string" },
            "silence_threshold_db": { "type": "number" },
            "min_silence_duration_sec": { "type": "number" },
            "compression_applied": { "type": "boolean" },
            "loudness_target_lufs": { "type": "number" }
          }
        }
      }
    },

    "p1_winner_profile": {
      "description": "Pipeline 1 (Winner Analysis) → Pipeline 4 (Scoring). One per analyzed winner video.",
      "type": "object",
      "required": ["video_id", "channel", "narrative_arc", "moment_types", "segment_stats"],
      "properties": {
        "video_id": {
          "type": "string",
          "description": "YouTube video ID"
        },
        "channel": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "view_count": {
          "type": "integer"
        },
        "duration_sec": {
          "type": "integer"
        },
        "narrative_arc": {
          "type": "object",
          "required": ["structure_type", "beats"],
          "properties": {
            "structure_type": {
              "type": "string",
              "enum": ["chronological", "cold_open", "parallel_timeline", "reveal_structure", "escalation"],
              "description": "High-level narrative structure used"
            },
            "beats": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["beat_type", "start_pct", "end_pct"],
                "properties": {
                  "beat_type": {
                    "type": "string",
                    "enum": ["hook", "setup", "escalation", "climax", "aftermath", "reveal", "context", "transition"],
                    "description": "Narrative beat type"
                  },
                  "start_pct": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "Position in video as fraction (0.0 = start, 1.0 = end)"
                  },
                  "end_pct": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "moment_types": {
          "type": "object",
          "description": "Count of each moment type identified in the video",
          "properties": {
            "contradiction": { "type": "integer" },
            "emotional_peak": { "type": "integer" },
            "procedural_violation": { "type": "integer" },
            "reveal": { "type": "integer" },
            "detail_noticed": { "type": "integer" },
            "callback": { "type": "integer" },
            "tension_shift": { "type": "integer" }
          }
        },
        "segment_stats": {
          "type": "object",
          "properties": {
            "avg_segment_length_sec": { "type": "number" },
            "total_segments": { "type": "integer" },
            "bodycam_pct": { "type": "number", "description": "Fraction of runtime that is bodycam footage" },
            "narration_pct": { "type": "number" },
            "interrogation_pct": { "type": "number" },
            "other_pct": { "type": "number" }
          }
        },
        "artifact_combination": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["bodycam", "interrogation", "911_audio", "court_video", "news_clips", "documents", "narration"]
          },
          "description": "Which artifact types were used in this video"
        }
      }
    },

    "p1_scoring_weights": {
      "description": "Aggregated scoring weights derived from winner analysis + comment calibration. Consumed by Pipeline 4.",
      "type": "object",
      "required": ["moment_weights", "arc_patterns", "artifact_value"],
      "properties": {
        "moment_weights": {
          "type": "object",
          "description": "How much each moment type contributes to narrative score (should sum to 1.0)",
          "properties": {
            "contradiction": { "type": "number" },
            "emotional_peak": { "type": "number" },
            "procedural_violation": { "type": "number" },
            "reveal": { "type": "number" },
            "detail_noticed": { "type": "number" },
            "callback": { "type": "number" },
            "tension_shift": { "type": "number" }
          }
        },
        "arc_patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "structure_type": { "type": "string" },
              "frequency": { "type": "number", "description": "How often this arc appears in winners (0-1)" },
              "avg_view_count": { "type": "integer" }
            }
          },
          "description": "Which narrative arcs correlate with performance"
        },
        "artifact_value": {
          "type": "object",
          "description": "Relative value of artifact combinations (higher = better content potential)",
          "additionalProperties": { "type": "number" }
        },
        "comment_calibration": {
          "type": "object",
          "description": "Moment type distribution from comment analysis (if available)",
          "properties": {
            "total_comments_analyzed": { "type": "integer" },
            "moment_distribution": {
              "type": "object",
              "additionalProperties": { "type": "number" }
            },
            "timestamp_comment_count": { "type": "integer" }
          }
        }
      }
    },

    "p4_to_p5_verdict": {
      "description": "Pipeline 4 (Scoring) → Pipeline 5 (Assembly). One per scored case.",
      "type": "object",
      "required": ["case_id", "verdict", "narrative_score", "key_moments", "content_pitch"],
      "properties": {
        "case_id": {
          "type": "string"
        },
        "verdict": {
          "type": "string",
          "enum": ["PRODUCE", "HOLD", "SKIP"],
          "description": "Final content decision"
        },
        "narrative_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Overall narrative potential score"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Model confidence in the verdict"
        },
        "key_moments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["moment_type", "timestamp_sec", "description", "importance"],
            "properties": {
              "moment_type": {
                "type": "string",
                "enum": ["contradiction", "emotional_peak", "procedural_violation", "reveal", "detail_noticed", "callback", "tension_shift"]
              },
              "timestamp_sec": {
                "type": "number",
                "description": "Original video timestamp"
              },
              "end_timestamp_sec": {
                "type": "number"
              },
              "description": {
                "type": "string"
              },
              "importance": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"],
                "description": "How important this moment is to the narrative"
              },
              "transcript_excerpt": {
                "type": "string",
                "description": "Brief excerpt of what was said"
              }
            }
          }
        },
        "content_pitch": {
          "type": "string",
          "description": "One-paragraph pitch for why this case should be produced"
        },
        "narrative_arc_recommendation": {
          "type": "string",
          "enum": ["chronological", "cold_open", "parallel_timeline", "reveal_structure", "escalation"],
          "description": "Suggested narrative structure based on winner patterns"
        },
        "estimated_runtime_min": {
          "type": "number",
          "description": "Estimated final content length in minutes"
        },
        "artifact_completeness": {
          "type": "object",
          "properties": {
            "available": {
              "type": "array",
              "items": { "type": "string" }
            },
            "missing_recommended": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Artifacts that winners typically have but this case lacks"
            }
          }
        },
        "scoring_breakdown": {
          "type": "object",
          "description": "How the score was calculated",
          "properties": {
            "moment_density_score": { "type": "number" },
            "arc_similarity_score": { "type": "number" },
            "artifact_completeness_score": { "type": "number" },
            "uniqueness_score": { "type": "number" }
          }
        },
        "transcript_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths to P3 transcript files used in scoring"
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths to P2 research files used"
        }
      }
    }
  }
}
