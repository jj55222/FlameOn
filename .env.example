# FlameOn — API Keys
# Copy to .env and fill in values. Each pipeline needs different keys.
# All keys have free tiers.

# Pipeline 2: Case Discovery
BRAVE_API_KEY=           # brave.com/search/api — 2K free requests/month
COURTLISTENER_API_KEY=   # courtlistener.com/sign-in/ — free
YOUTUBE_API_KEY=         # console.cloud.google.com — 10K units/day free (optional, youtube-search-python is free/unlimited)
MUCKROCK_API_TOKEN=      # optional, public read works without auth
FIRECRAWL_API_KEY=       # firecrawl.dev — 500 free credits/month
EXA_API_KEY=             # exa.ai — free tier

# Pipeline 1: Winner Analysis + Pipeline 4: Transcript Analysis (Pass 1)
GEMINI_API_KEY=          # aistudio.google.com — free tier

# Pipeline 4: Transcript Analysis (Pass 2)
ANTHROPIC_API_KEY=       # console.anthropic.com

# Pipeline 3: Audio Preprocessing (diarization)
HF_TOKEN=               # huggingface.co/settings/tokens
                         # Also accept license at: huggingface.co/pyannote/speaker-diarization-3.1
